# =====================================================================
# Coastline Electrical Co. — environment variables
# Copy this file to ".env" (local) and set the same values in your host's
# dashboard (Vercel / Netlify / Cloudflare Pages / Render, etc.).
# NEVER commit real secret values. .env is gitignored.
# =====================================================================

# ---- Public (safe to expose in the browser) ----
# Used to build the GoHighLevel calendar embed and links.
NEXT_PUBLIC_GHL_LOCATION_ID=
NEXT_PUBLIC_GHL_CALENDAR_ID=
# The hosted LeadConnector booking widget URL (used by the optional
# "Book through our calendar" iframe on book.html).
NEXT_PUBLIC_GHL_BOOKING_URL=

# ---- Secret (server-only — read by the /functions routes) ----
# Create three Inbound Webhook triggers in GoHighLevel (Automation ->
# Workflows -> trigger "Inbound Webhook") and paste the URLs here.
GHL_CONTACT_WEBHOOK_URL=
GHL_BOOKING_WEBHOOK_URL=
GHL_CHATBOT_WEBHOOK_URL=

# ---- Optional: GoHighLevel REST API (only if you move off Inbound Webhooks) ----
# GHL_API_TOKEN=
# GHL_API_VERSION=2021-07-28

# Note: this is a static site, so the NEXT_PUBLIC_* names are a convention only
# (there is no Next.js build step). The public values are mirrored in
# lib/integrations.js; the secret GHL_*_WEBHOOK_URL values are read at runtime
# by the serverless functions and are never exposed to the browser.
